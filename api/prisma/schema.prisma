datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/db"
}

enum Role {
  AUTOBIOGRAPHER
  ADVERTISER
  BIOGRAPHER
  MODERATOR
}

model User {
  id            String       @id @default(cuid())
  forename      String
  surname       String
  username      String       @unique
  email         String       @unique
  password      String
  createdAt     DateTime     @default(now())
  deletedAt     DateTime?
  role          Role         @default(AUTOBIOGRAPHER)
  following     FollowUser[] @relation("following")
  followers     FollowUser[] @relation("follower")
  tagsFollowing FollowTag[]
  posts         Post[]
  comments      Comment[]
}

// Join table representing a many-to-many self-referencing relationship on the User model.
model FollowUser {
  followerId  String
  followingId String
  follower    User   @relation("following", fields: [followerId], references: [id])
  following   User   @relation("follower", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

model FollowTag {
  userId String
  tagId  String
  user   User   @relation(fields: [userId], references: [id])
  tag    Tags   @relation(fields: [tagId], references: [id])

  @@id([userId, tagId])
}

model Post {
  id         String       @id @default(cuid())
  authorId   String
  author     User         @relation(fields: [authorId], references: [id])
  tags       Tags[]
  title      String
  content    Json
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  published  Boolean      @default(false)
  impression Impressions?
  deletedAt  DateTime?
}

model Tags {
  id        String      @id @default(cuid())
  name      String
  posts     Post[]
  followers FollowTag[]
}

model Impressions {
  postId String @id
  post   Post   @relation(fields: [postId], references: [id])

  views    Int @default(0)
  likes    Int @default(0)
  dislikes Int @default(0)

  comments Comment[]
}

model Comment {
  id        String      @id @default(cuid())
  postId    String
  authorId  String
  post      Impressions @relation(fields: [postId], references: [postId])
  author    User        @relation(fields: [authorId], references: [id])
  text      String
  createdAt DateTime    @default(now())
}
