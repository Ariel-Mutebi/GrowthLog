{
  "name": "growth-log-api",
  "version": "1.0.0",
  "description": "REST API for a blogging platform about self-improvement",
  "private": "true",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepare": "husky",
    "system:up": "docker compose up --build",
    "system:down": "docker compose down",
    "system:logs": "docker compose logs -f",
    "system:restart": "docker compose up --build app",
    "test": "node --test"
  },
  "author": "Ariel Robert Mutebi",
  "license": "BUSL-1.1",
  "type": "module",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/passport": "^3.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/session": "^11.1.1",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sinclair/typebox": "^0.34.49",
    "bcrypt": "^6.0.0",
    "fastify": "^5.8.5",
    "jiti": "^2.6.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.6.0",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "overrides": {
    "@hono/node-server": ">=1.19.13"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "git add"
    ]
  }
}
